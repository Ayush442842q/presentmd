{
  "name": "presentmd",
  "version": "0.1.0",
  "description": "Markdown-to-Presentation desktop app",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist:win": "electron-vite build && electron-builder --win --dir",
    "dist:win-installer": "electron-vite build && electron-builder --win nsis"
  },
  "dependencies": {
    "@codemirror/commands": "^6.3.3",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/lang-markdown": "^6.2.5",
    "@codemirror/language": "^6.10.1",
    "@codemirror/search": "^6.5.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.26.3",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "dompurify": "^3.1.5",
    "electron-store": "^7.0.3",
    "highlight.js": "^11.9.0",
    "markdown-it": "^14.1.0",
    "markdown-it-container": "^3.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.4.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^14.1.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.presentmd.app",
    "productName": "PresentMD",
    "directories": { "output": "dist" },
    "files": ["out/**/*", "resources/**/*"],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    }
  }
}