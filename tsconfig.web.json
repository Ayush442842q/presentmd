{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "target": "ES2022",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "out",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "baseUrl": "."
  },
  "include": ["src/renderer/src/**/*"]
}
